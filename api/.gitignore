## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Compiled files
bin/
obj/
.vs/
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider
.idea/
*.sln.iml

# Environment files
appsettings.local.json
.env
.env.local

# Dependencies
packages/
node_modules/

# Build output
*.dll
*.exe
*.pdb
